# Docket runtime env. Copy to docket-runtime.env and fill in.
#
# This file is the recommended home for Jira credentials, NOT system environment
# variables. The VS Code extension host inherits its environment from whenever
# VS Code was launched - so `set JIRA_PAT=...` in a terminal is invisible to it,
# and a system variable needs a full VS Code restart to take effect. This file is
# read at runtime by loop.py, so it works either way with no restart.
#
# .local/ and *-runtime.env are gitignored. Never commit the real one.
# Anything already exported in your environment wins over these.

JIRA_BASE_URL=https://jira.company.com
JIRA_PAT=

# Optional. Comma-separated customfield IDs to check FIRST for acceptance
# criteria. Leave blank until you know yours - run:
#     python scripts/jira_fetch.py PROJ-110
# and read the "AC source:" line. If it says custom_field:customfield_10300,
# pin that here to skip the search on every future run.
JIRA_AC_FIELD_IDS=
