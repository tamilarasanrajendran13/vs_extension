{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run Docket (dev sandbox)",
      "type": "extensionHost",
      "request": "launch",
      "args": ["--extensionDevelopmentPath=${workspaceFolder}"]
    },
    {
      "name": "Run Docket (auto-open my repo)",
      "type": "extensionHost",
      "request": "launch",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}",
        "REPLACE_WITH_ABSOLUTE_PATH_TO_YOUR_REPO"
      ]
    }
  ]
}
