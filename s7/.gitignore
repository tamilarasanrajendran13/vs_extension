# The ledger is per-machine state. SQLite in git is a merge-conflict machine.
# If it must span machines, point config.ledger.db at a shared path instead.
*.db
*.db-wal
*.db-shm

# Probe output
docket-probe-result.json
docket-preflight.json

# Caches
.docket/cache/
__pycache__/
*.pyc
.venv/
venv/

# Never - even though config.json only holds env var NAMES
.env

# Runtime state, lives in this folder but never in git
workspaces/

# Secrets. Never.
.local/
*-runtime.env
